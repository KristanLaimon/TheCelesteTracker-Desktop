---
import Layout from "../Layout.astro";
import RecentRunsTable from "../components/index/RecentRunsTable.svelte";
import GeneralInfoGrid from "../components/index/GeneralInfoGrid.svelte";
import farewellBanner from "../assets/bg_horizontal_farewell_banner.jpg";
import madelineArtwork from "../assets/madeline_artwork_pendingcredits.png";

import HeaderBerry from "../components/global/HeaderBerry.astro";

import IconSettings from "~icons/material-symbols/settings";
import IconNotifications from "~icons/material-symbols/notifications";
import IconDashboard from "~icons/material-symbols/dashboard";
import IconMountainFlag from "~icons/material-symbols/mountain-flag";
import IconExtension from "~icons/material-symbols/extension";
import IconLeaderboard from "~icons/material-symbols/leaderboard";
import IconMap from "~icons/material-symbols/map";
import IconHistory from "~icons/material-symbols/history";
import IconTerminal from "~icons/material-symbols/terminal";
import IconWifi from "~icons/material-symbols/wifi";
---

<Layout
  title="Main page!"
  bodyClassNames="antialiased selection:bg-primary selection:text-white bg-bg-base text-zinc-100 font-body"
  bodyId="page-hub"
>
  <style>
    @keyframes drift {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }
    .mountain-bg {
      background: linear-gradient(to bottom, #1a1a1e 0%, #131315 100%);
    }
    .peak {
      clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
    }
  </style>

  <!-- Main Content -->
  <main class="pt-16 pb-20">
    <!-- Hero Section -->
    <section class="relative h-[300px] md:h-[400px] w-full overflow-hidden mountain-bg">
      <!-- Background Image -->
      <div class="absolute inset-0 z-0">
        <img src={farewellBanner.src} alt="Farewell Background" class="w-full h-full object-cover opacity-40" />
        <div class="absolute inset-0 bg-hero-gradient"></div>
        <div class="absolute inset-0 bg-linear-to-t from-bg-base via-transparent to-transparent"></div>
      </div>

      <div class="relative z-10 h-full flex items-center justify-between px-6 md:px-12">
        <div class="pb-12 max-w-2xl">
          <h1 class="text-5xl md:text-7xl font-headline font-bold text-white tracking-tighter mb-4">
            Celeste <span class="text-primary italic">Tracker</span>
          </h1>
          <p class="text-zinc-400 text-lg md:text-xl leading-relaxed font-medium">
            Your mountain progress and all the stats you need.
          </p>
        </div>

        <div class="hidden lg:block relative group">
          <div class="absolute inset-0 bg-primary/20 blur-3xl group-hover:bg-primary/30 transition-all"></div>
          <img
            alt="Madeline Artwork"
            class="relative w-[250px] drop-shadow-[0_0_30px_rgba(255,120,140,0.3)] group-hover:scale-105 transition-transform duration-700 right-10"
            src={madelineArtwork.src}
          />
        </div>
      </div>
    </section>
    <!-- Navigation Cards Grid -->
    <section class="px-6 md:px-12 -mt-6 relative z-20">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4">
        <!-- Dashboard / Overview -->
        <a
          class="bg-card-bg border border-outline-muted p-6 rounded-2xl hover:border-primary/50 transition-all group opacity-50 pointer-events-none"
          href="#"
        >
          <IconDashboard class="text-primary text-3xl mb-4 block group-hover:scale-110 transition-transform" />
          <h3 class="font-headline font-bold text-white text-lg">Dashboard</h3>
          <p class="text-xs text-zinc-500 mt-1">Overall progress &amp; stats</p>
        </a>
        <!-- Vanilla Chapters -->
        <a
          class="bg-card-bg border border-outline-muted p-6 rounded-2xl hover:border-secondary/50 transition-all group opacity-50 pointer-events-none"
          href="#"
        >
          <IconMountainFlag class="text-secondary text-3xl mb-4 block group-hover:scale-110 transition-transform" />
          <h3 class="font-headline font-bold text-white text-lg">Vanilla Chapters</h3>
          <p class="text-xs text-zinc-500 mt-1">Classic climb tracking</p>
        </a>
        <!-- Modded Content -->
        <a
          class="bg-card-bg border border-outline-muted p-6 rounded-2xl hover:border-tertiary/50 transition-all group opacity-50 pointer-events-none"
          href="#"
        >
          <IconExtension class="text-tertiary text-3xl mb-4 block group-hover:scale-110 transition-transform" />
          <h3 class="font-headline font-bold text-white text-lg">Modded Content</h3>
          <p class="text-xs text-zinc-500 mt-1">Everest &amp; custom maps</p>
        </a>
        <!-- CSR Roadmap -->
        <a
          class="bg-card-bg border border-outline-muted p-6 rounded-2xl hover:border-purple-400/50 transition-all group opacity-50 pointer-events-none"
          href="#"
        >
          <IconLeaderboard class="text-purple-400 text-3xl mb-4 block group-hover:scale-110 transition-transform" />
          <h3 class="font-headline font-bold text-white text-lg">CSR Roadmap</h3>
          <p class="text-xs text-zinc-500 mt-1">Global ranking goals</p>
        </a>
        <!-- Map Collections -->
        <a
          class="bg-card-bg border border-outline-muted p-6 rounded-2xl hover:border-orange-400/50 transition-all group"
          href="#"
        >
          <IconMap class="text-orange-400 text-3xl mb-4 block group-hover:scale-110 transition-transform" />
          <h3 class="font-headline font-bold text-white text-lg">Collections</h3>
          <p class="text-xs text-zinc-500 mt-1">Organize your levels</p>
        </a>
        <!-- History -->
        <a
          class="bg-card-bg border border-outline-muted p-6 rounded-2xl hover:border-blue-400/50 transition-all group"
          href="#"
        >
          <IconHistory class="text-blue-400 text-3xl mb-4 block group-hover:scale-110 transition-transform" />
          <h3 class="font-headline font-bold text-white text-lg">Run History</h3>
          <p class="text-xs text-zinc-500 mt-1">Full archive of ascents</p>
        </a>
      </div>
    </section>
    <!-- General Info Grid -->
    <section class="px-6 md:px-12 mt-12">
      <GeneralInfoGrid client:load />
    </section>
    <!-- Recent Run History Section -->
    <section class="px-6 md:px-12 mt-12">
      <RecentRunsTable client:load />
    </section>
  </main>
  <!-- Footer -->
  <footer
    class="fixed bottom-0 left-0 w-full h-10 bg-zinc-950 border-t border-outline-muted flex items-center justify-between px-6 z-50"
  >
    <div class="flex items-center gap-4 text-[11px] font-medium text-zinc-500">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-secondary"></span>
        <span class="hidden sm:inline">Everest Core: v1.3452.0-stable</span>
        <span class="sm:hidden">Everest Core</span>
      </div>
      <div class="h-3 w-px bg-outline-muted"></div>
      <div class="flex items-center gap-2">
        <IconTerminal class="text-xs" />
        <span>System Ready</span>
      </div>
    </div>
    <div class="flex items-center gap-4 md:gap-6 text-[11px] font-medium text-zinc-500">
      <span class="hover:text-primary cursor-pointer transition-colors hidden md:inline">GitHub Repository</span>
      <span class="hover:text-primary cursor-pointer transition-colors hidden md:inline">API Documentation</span>
      <div class="bg-zinc-900 px-2 py-0.5 rounded flex items-center gap-2">
        <IconWifi class="text-[10px]" />
        <span class="hidden xs:inline">Synchronized</span>
      </div>
    </div>
  </footer>
</Layout>

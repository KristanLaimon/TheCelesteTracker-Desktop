---
import Layout from "../../Layout.astro";
import CollectionList from "@components/collections/CollectionList/CollectionList.svelte";
import IconMap from "~icons/material-symbols/map";
---

<Layout
  title="Collections"
  bodyClassNames="antialiased selection:bg-primary selection:text-white bg-bg-base text-zinc-100 font-body"
>
  <main class="min-h-screen pb-20 pt-12">
    <div class="px-6 md:px-12 max-w-7xl mx-auto">
      <!-- Header -->
      <div class="flex items-center gap-4 mb-12">
        <div class="w-12 h-12 rounded-xl bg-orange-400/20 flex items-center justify-center text-orange-400">
            <IconMap class="text-2xl" />
        </div>
        <div>
          <h1 class="text-4xl font-headline font-bold text-white tracking-tight">Map <span class="text-orange-400">Collections</span></h1>
          <p class="text-zinc-500 font-medium">Create custom sets of campaigns and chapters to track them together.</p>
        </div>
      </div>

      <!-- Collections List -->
      <CollectionList client:load />
    </div>
  </main>
</Layout>

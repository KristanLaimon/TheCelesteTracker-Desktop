---
import Layout from "../../Layout.astro";
import StrawberryJamOverview from "@components/strawberry-jam/StrawberryJamOverview.svelte";
import IconFlag from "~icons/material-symbols/flag";
---

<Layout
  title="Strawberry Jam"
  bodyClassNames="antialiased selection:bg-primary selection:text-white bg-bg-base text-zinc-100 font-body"
>
  <main class="min-h-screen pb-20 pt-12">
    <div class="px-6 md:px-12 max-w-7xl mx-auto">
      <div class="flex items-center gap-4 mb-12">
        <div class="w-12 h-12 rounded-xl bg-pink-400/20 flex items-center justify-center text-pink-400">
          <IconFlag class="text-2xl" />
        </div>
        <div>
          <h1 class="text-4xl font-headline font-bold text-white tracking-tight">
            Strawberry <span class="text-pink-400">Jam</span>
          </h1>
          <p class="text-zinc-500 font-medium">Lobby tiers and tracked progress.</p>
        </div>
      </div>

      <StrawberryJamOverview client:load />
    </div>
  </main>
</Layout>
